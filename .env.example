# === Timeout Configuration (all values in milliseconds unless noted) ===
# Note: Most timeouts have sensible defaults. Only override if needed for your environment.

# Browser navigation timeouts
# TIMEOUT_PAGE_NAVIGATION=0 # Page navigation timeout (0 = unlimited)
# TIMEOUT_PAGE_API_RESPONSE=30000 # Wait for API response after page load (30s)

# UI element interaction timeouts
# TIMEOUT_POPUP_CLOSE=2000 # Popup close button click timeout (2s)
# TIMEOUT_TEXTAREA_WAIT=3000 # Textarea visibility timeout (3s)
# TIMEOUT_CREATE_BUTTON_WAIT=5000 # Create button visibility timeout (5s)

# CAPTCHA solving timeouts
# TIMEOUT_CAPTCHA_SCREENSHOT=5000 # CAPTCHA screenshot timeout (5s)
# TIMEOUT_CAPTCHA_IMAGE_LOAD=3 # hCaptcha image load delay in SECONDS (3s)
# TIMEOUT_CAPTCHA_PIECE_UNLOCK=1.1 # CAPTCHA piece unlock delay in SECONDS (1.1s)

# API request timeouts
# TIMEOUT_API_CONCATENATE=10000 # Concatenate endpoint timeout (10s)
# TIMEOUT_API_GENERATE=10000 # Generate endpoint timeout (10s)
# TIMEOUT_API_FEED=10000 # Feed endpoint timeout (10s)
# TIMEOUT_API_PERSONA=10000 # Persona endpoint timeout (10s)

# Polling and delay configurations (sleep delays in SECONDS)
# TIMEOUT_KEEP_ALIVE_MIN=1 # Min keepAlive sleep delay in SECONDS (1s)
# TIMEOUT_KEEP_ALIVE_MAX=2 # Max keepAlive sleep delay in SECONDS (2s)
# TIMEOUT_LYRICS_POLL=2 # Lyrics generation poll delay in SECONDS (2s)
# TIMEOUT_AUDIO_POLL_MIN=3 # Min audio poll delay in SECONDS (3s)
# TIMEOUT_AUDIO_POLL_MAX=6 # Max audio poll delay in SECONDS (6s)
# TIMEOUT_AUDIO_POLL_INITIAL=5 # Initial delay before audio polling in SECONDS (5s)

# Overall operation timeouts
# TIMEOUT_AUDIO_GENERATION_MAX=100000 # Max audio generation wait time (100s)